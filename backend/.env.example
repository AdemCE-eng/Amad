# ── Server ───────────────────────────────────────────────
PORT=3000

# ── Firebase ─────────────────────────────────────────────
# Any string works for the emulator; use the real project id when going live.
FIREBASE_PROJECT_ID=amad-demo

# LOCAL (default): point firebase-admin at the emulator. Comment this out for production.
FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000

# The emulator accepts any URL with a valid-looking namespace.
FIREBASE_DATABASE_URL=https://amad-demo-default-rtdb.firebaseio.com

# PRODUCTION only: path to a service-account JSON key (leave blank for emulator).
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# ── Gemini AI ────────────────────────────────────────────
# true  = use hardcoded fallback responses (no key needed) — great for building/demo safety.
# false = call the real Gemini API (requires GEMINI_API_KEY).
USE_MOCK_AI=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
